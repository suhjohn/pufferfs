config:
  aws:region: "us-east-1"

  pufferfs:projectName: "pufferfs"
  pufferfs:availabilityZones:
    - "us-east-1a"
    - "us-east-1b"
  pufferfs:vpcCidr: "10.80.0.0/16"
  pufferfs:imageTag: "prod"

  pufferfs:databaseUrl:
    secure: "pulumi-secret-postgres-url"
  pufferfs:jwtSecret:
    secure: "pulumi-secret-jwt-secret"
  pufferfs:turbopufferApiKey:
    secure: "pulumi-secret-turbopuffer-api-key"
  pufferfs:adminKeyHash:
    secure: "optional-admin-key-sha256"

  pufferfs:modalChunkEndpoint: "https://...chunk-file-endpoint.modal.run"
  pufferfs:modalEmbedEndpoint: "https://...embed-chunks-endpoint.modal.run"
  pufferfs:modalQueryEmbedEndpoint: "https://...embed-query-endpoint.modal.run"
  pufferfs:modalChunkShardEndpoint: "https://...chunk-shard-endpoint.modal.run"
  pufferfs:modalEmbedShardEndpoint: "https://...embed-shard-endpoint.modal.run"
  pufferfs:modalIndexShardEndpoint: "https://...index-shard-endpoint.modal.run"

  # CLI release manifest advertised at GET /cli/version.
  pufferfs:cliLatestVersion: "0.3.0"
  pufferfs:cliMinVersion: "0.2.0"
  pufferfs:cliDownloadBaseUrl: "https://github.com/suhjohn/pufferfs/releases/download"

  # Frontend + Google login. DNS is in Cloudflare; *HttpsReady stays false until
  # the ACM certs validate (see README "Custom domains").
  pufferfs:webDomain: "pufferfs.com"
  pufferfs:apiDomain: "api.pufferfs.com"
  pufferfs:frontendUrl: "https://pufferfs.com"
  pufferfs:cookieDomain: ".pufferfs.com"
  pufferfs:oauthRedirectUrl: "https://api.pufferfs.com/auth/callback"
  pufferfs:googleClientId: "xxxx.apps.googleusercontent.com"
  pufferfs:googleClientSecret:
    secure: "pulumi-secret-google-client-secret"
  pufferfs:webHttpsReady: false
  pufferfs:apiHttpsReady: false

  # Billing (optional). Leave disabled to deploy without payments.
  pufferfs:enableBilling: false
  # pufferfs:stripePriceId: "price_xxx"
  # pufferfs:stripeSecretKey:
  #   secure: "pulumi-secret-stripe-secret-key"
  # pufferfs:stripeWebhookSecret:
  #   secure: "pulumi-secret-stripe-webhook-secret"

  pufferfs:apiDesiredCount: 2
  pufferfs:worker-chunkDesiredCount: 1
  pufferfs:worker-embedDesiredCount: 1
  pufferfs:worker-indexDesiredCount: 1
  pufferfs:worker-commitDesiredCount: 1
  pufferfs:worker-cleanupDesiredCount: 1
  pufferfs:tpNamespaceShards: 4
