# Base URL of the Go API. In prod this is the api.* subdomain.
VITE_API_URL=http://localhost:8080

# Toggle the payment/billing surface. When false, the Billing nav item and
# /billing route are hidden and the deployment needs no Stripe config.
VITE_ENABLE_BILLING=false

# Optional analytics. VITE_POSTHOG_KEY is the browser-safe PostHog project token.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
