# Copy to .env and fill in. .env is git-ignored — never commit real values.
# Secret-marked keys are pushed with `pulumi config set --secret` (encrypted).

# --- AWS / Pulumi ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
PULUMI_CONFIG_PASSPHRASE=          # secret: encrypts Pulumi config

# --- Core API (secret) ---
DATABASE_URL=                      # secret
JWT_SECRET=                        # secret
TURBOPUFFER_API_KEY=               # secret
# PUFFERFS_ADMIN_KEY_HASH=         # secret, optional

# --- Modal endpoints ---
MODAL_CHUNK_ENDPOINT=
MODAL_EMBED_ENDPOINT=
MODAL_QUERY_EMBED_ENDPOINT=
MODAL_CHUNK_SHARD_ENDPOINT=
MODAL_EMBED_SHARD_ENDPOINT=
MODAL_INDEX_SHARD_ENDPOINT=

# --- Frontend + Google login (required for the web app) ---
WEB_DOMAIN=pufferfs.com
API_DOMAIN=api.pufferfs.com
FRONTEND_URL=https://pufferfs.com
COOKIE_DOMAIN=.pufferfs.com
OAUTH_REDIRECT_URL=https://api.pufferfs.com/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=              # secret
VITE_API_URL=https://api.pufferfs.com   # web build-time
VITE_POSTHOG_KEY=                       # web build-time, browser-safe PostHog project token
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Product analytics (optional, backend/server-side) ---
POSTHOG_ENABLED=false
POSTHOG_KEY=                            # secret-ish project token; same value as VITE_POSTHOG_KEY when using one project
POSTHOG_HOST=https://us.i.posthog.com

# --- Invite email via AWS SES (optional) ---
# Leave INVITE_EMAIL_FROM empty to keep invites database-only.
# Set INVITE_EMAIL_IDENTITY to a domain/email for Pulumi to create an SES identity
# and output DKIM DNS records, or omit it when using an already-verified identity.
# INVITE_EMAIL_FROM=team@pufferfs.com
# INVITE_EMAIL_FROM_NAME=PufferFS
# INVITE_EMAIL_REPLY_TO=support@pufferfs.com
# INVITE_EMAIL_APP_URL=https://pufferfs.com
# INVITE_EMAIL_SES_REGION=us-west-2
# INVITE_EMAIL_IDENTITY=pufferfs.com
# INVITE_EMAIL_IDENTITY_ARN=arn:aws:ses:us-west-2:123456789012:identity/pufferfs.com
# SES_CONFIGURATION_SET=
# SES_FEEDBACK_EMAIL=

# --- HTTPS phase-2 flags: set true only after ACM certs show Issued ---
API_HTTPS_READY=false
WEB_HTTPS_READY=false

# --- Billing (optional; leave false to deploy without payments) ---
ENABLE_BILLING=false
VITE_ENABLE_BILLING=false          # web build-time, match ENABLE_BILLING
# STRIPE_SECRET_KEY=               # secret, only when ENABLE_BILLING=true
# STRIPE_WEBHOOK_SECRET=           # secret, only when ENABLE_BILLING=true
# STRIPE_PRICE_ID=                 # only when ENABLE_BILLING=true
