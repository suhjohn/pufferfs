# Copy to .env and fill in. .env is git-ignored — never commit real values.
# Secret-marked keys are pushed with `pulumi config set --secret` (encrypted).

# --- AWS / Pulumi ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
PULUMI_CONFIG_PASSPHRASE=          # secret: encrypts Pulumi config

# --- Core API (secret) ---
DATABASE_URL=                      # secret
JWT_SECRET=                        # secret
TURBOPUFFER_API_KEY=               # secret
# PUFFERFS_ADMIN_KEY_HASH=         # secret, optional

# --- Modal endpoints ---
MODAL_CHUNK_ENDPOINT=
MODAL_EMBED_ENDPOINT=
MODAL_QUERY_EMBED_ENDPOINT=
MODAL_CHUNK_SHARD_ENDPOINT=
MODAL_EMBED_SHARD_ENDPOINT=
MODAL_INDEX_SHARD_ENDPOINT=
# Optional public Modal conversion endpoints for direct callers.
MODAL_OFFICE_TO_PDF_ENDPOINT=
MODAL_PDF_TO_PAGE_IMAGES_ENDPOINT=
PUFFERFS_MODAL_PAGE_IMAGE_DPI=160
PUFFERFS_MODAL_PAGE_IMAGE_JPEG_QUALITY=75
PUFFERFS_MODAL_PAGE_IMAGE_UPLOAD_CONCURRENCY=512
PUFFERFS_PDF_RENDERER_INSTALL_URL=https://raw.githubusercontent.com/suhjohn/frpdf-renderer/main/install.sh
PUFFERFS_PDF_RENDERER_VERSION=v0.1.1
PUFFERFS_PDF_RENDERER_PATH=/usr/local/bin/frpdf
PUFFERFS_PDF_RENDERER_JOBS=
PUFFERFS_MODAL_OCR_MAX_CONTAINERS=100
PUFFERFS_MODAL_SECRET_NAME=pufferfs
# Optional weights use provider/model:weight. Weights are relative.
PUFFERFS_VLLM_MODELS=fireworks/accounts/fireworks/models/qwen3p7-plus:5,openai/gpt-5.4-nano:40,openai/gpt-5.4-mini:15,gemini/gemini-3.1-flash-lite:10,gemini/gemini-2.5-flash-lite:30
# Modal runtime credentials are stored in the Modal secret named by
# PUFFERFS_MODAL_SECRET_NAME. Include MODAL_SECRET_KEY there to authorize
# direct calls to the public conversion endpoints.

# --- Frontend + login ---
WEB_DOMAIN=pufferfs.com
API_DOMAIN=api.pufferfs.com
FRONTEND_URL=https://pufferfs.com
COOKIE_DOMAIN=.pufferfs.com
ENABLE_EMAIL_LOGIN=true
OAUTH_REDIRECT_URL=https://api.pufferfs.com/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=              # secret
VITE_API_URL=https://api.pufferfs.com   # web build-time
VITE_POSTHOG_KEY=                       # web build-time, browser-safe PostHog project token
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Product analytics (optional, backend/server-side) ---
POSTHOG_ENABLED=false
POSTHOG_KEY=                            # secret-ish project token; same value as VITE_POSTHOG_KEY when using one project
POSTHOG_HOST=https://us.i.posthog.com

# --- Transactional email via AWS SES (required for email-code login) ---
# Leave TRANSACTIONAL_EMAIL_FROM empty to keep invites database-only and make
# email-code login unavailable.
# Set TRANSACTIONAL_EMAIL_IDENTITY to a domain/email for Pulumi to create an SES identity
# and output DKIM DNS records, or omit it when using an already-verified identity.
# TRANSACTIONAL_EMAIL_FROM=team@pufferfs.com
# TRANSACTIONAL_EMAIL_FROM_NAME=PufferFS
# TRANSACTIONAL_EMAIL_REPLY_TO=support@pufferfs.com
# TRANSACTIONAL_EMAIL_APP_URL=https://pufferfs.com
# TRANSACTIONAL_EMAIL_SES_REGION=us-west-2
# TRANSACTIONAL_EMAIL_IDENTITY=pufferfs.com
# TRANSACTIONAL_EMAIL_IDENTITY_ARN=arn:aws:ses:us-west-2:123456789012:identity/pufferfs.com
# SES_CONFIGURATION_SET=
# SES_FEEDBACK_EMAIL=

# --- HTTPS phase-2 flags: set true only after ACM certs show Issued ---
API_HTTPS_READY=false
WEB_HTTPS_READY=false

# --- Billing (optional; leave false to deploy without payments) ---
ENABLE_BILLING=false
VITE_ENABLE_BILLING=false          # web build-time, match ENABLE_BILLING
# STRIPE_SECRET_KEY=               # secret, only when ENABLE_BILLING=true
# STRIPE_WEBHOOK_SECRET=           # secret, only when ENABLE_BILLING=true
# STRIPE_PRICE_ID=                 # only when ENABLE_BILLING=true
